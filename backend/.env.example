# Copy to `.env` and adjust as needed. In Docker these are set via docker-compose.

# Public API that Service A ingests products from
PUBLIC_API_URL=https://dummyjson.com/products?limit=100

# MongoDB (Service A)
MONGO_HOST=localhost

# Redis (Service A & B) — Pub/Sub + RedisTimeSeries
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL (Service B)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=analytics_db

# gRPC report-service (Service B -> Go)
REPORT_GRPC_URL=localhost:50051
